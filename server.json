{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.benmilne-com/benmilne",
  "description": "Read-only MCP server for benmilne.com — search posts, retrieve content, and discover information about Ben Milne. Public, unauthenticated, CORS-enabled.",
  "repository": {
    "url": "https://github.com/benmilne-com/agents",
    "source": "github"
  },
  "version": "1.0.0",
  "websiteUrl": "https://benmilne.com/developers",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://benmilne.com/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "benmilne-api",
      "version": "1.0.5",
      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "pypi",
      "identifier": "benmilne-api",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
